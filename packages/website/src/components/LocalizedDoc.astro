---
// Renders English + Chinese Markdown for a component side-by-side in the DOM,
// then toggles visibility client-side based on the active language.
//
// Both docs are imported at build time; the inline script reads the persisted
// language from localStorage (shared key with the language pill) and adds a
// `lang` attribute on the wrapper. CSS shows only the matching block.
//
// On top of the EN docs we also render live previews for each ```vue code
// block found in the EN markdown. The previews are Vue islands hydrated
// lazily (client:visible); each one resolves a virtual SFC module produced by
// the preview Vite plugin, so there is no runtime template compiler.

import PreviewFrame from './vue/PreviewFrame.vue';
import { codeToHtml } from 'shiki';
import { t } from '../i18n/lang';

interface Props {
  en: unknown; // markdown module: { Content, rawContent, file, ... }
  zh: unknown;
}

const { en, zh } = Astro.props;

const En = (en as { Content: any }).Content;
const Zh = (zh as { Content: any }).Content;

// Derive the component slug + subfolder from the EN markdown file path:
//   .../docs/components/<slug>/<subfolder>/<subfolder>_English.md
// The preview registry key is `<slug>__<subfolder>-<index>`.
const enFile = (en as { file?: string }).file || '';
const pathMatch = enFile.match(/docs\/components\/([^/]+)\/([^/]+)\//);
const slug = pathMatch ? pathMatch[1] : '';
const subfolder = pathMatch ? pathMatch[2] : '';

// Extract every ```vue fenced code block from the raw EN markdown so we can
// render a live preview for each. Blocks without a <template> are skipped
// (they aren't renderable — e.g. pure `import` snippets).
const rawEn = typeof (en as { rawContent?: () => string }).rawContent === 'function'
  ? (en as { rawContent: () => string }).rawContent()
  : '';
const vueBlocks: { index: number; code: string }[] = [];
if (rawEn) {
  const re = /```vue\s*\n([\s\S]*?)```/g;
  let m: RegExpExecArray | null;
  let count = 0;
  while ((m = re.exec(rawEn)) !== null) {
    const code = m[1];
    if (/<template[\s>]/i.test(code)) {
      vueBlocks.push({ index: count, code });
    }
    count++;
  }
}

const highlightedVueBlocks = await Promise.all(
  vueBlocks.map(async (block) => ({
    ...block,
    codeHtml: await codeToHtml(block.code, {
      lang: 'vue',
      themes: {
        light: 'one-light',
        dark: 'one-dark-pro',
      },
    }),
  })),
);

// Build the preview registry key for each block: <slug>__<subfolder>-<index>
const previewKey = (index: number) => `${slug}__${subfolder}-${index}`;
---

<div class="localized-doc" data-lang="en">
  <div class="localized-doc__pane" data-lang="en">
    <En />
  </div>
  <div class="localized-doc__pane" data-lang="zh">
    <Zh />
  </div>
  {
    vueBlocks.length > 0 && (
      <div class="component-previews">
        <h2 class="component-previews__title">
          <span class="localized-doc__inline" data-lang="en">{t('en', 'components.previews')}</span>
          <span class="localized-doc__inline" data-lang="zh">{t('zh', 'components.previews')}</span>
        </h2>
        <div class="component-previews__list">
          {highlightedVueBlocks.map((b) => (
            <PreviewFrame
              client:only="vue"
              previewKey={previewKey(b.index)}
              code={b.code}
              codeHtml={b.codeHtml}
            />
          ))}
        </div>
      </div>
    )
  }
</div>

<style is:global>
  .localized-doc[data-lang='en'] > .localized-doc__pane[data-lang='zh'],
  .localized-doc[data-lang='zh'] > .localized-doc__pane[data-lang='en'] {
    display: none;
  }

  .localized-doc[data-lang='en'] .localized-doc__inline[data-lang='zh'],
  .localized-doc[data-lang='zh'] .localized-doc__inline[data-lang='en'] {
    display: none;
  }
</style>

<script is:inline>
  (() => {
    // Apply the persisted language to every .localized-doc on the page.
    // The global listeners are registered once (guarded by a window flag)
    // so re-injecting this script on each page doesn't pile up handlers.
    const applyDocLang = (lang) => {
      const target = lang === 'zh' ? 'zh' : 'en';
      document.querySelectorAll('.localized-doc').forEach((el) => {
        el.setAttribute('data-lang', target);
      });
      document.documentElement.setAttribute('lang', target === 'zh' ? 'zh-CN' : 'en');
      document.documentElement.setAttribute('data-lang', target);
      window.dispatchEvent(new CustomEvent('anyui:lang-applied', { detail: target }));
    };
    const readDocLang = () => {
      try {
        return JSON.parse(localStorage.getItem('anyui-site-prefs') || '{}').lang;
      } catch {
        return undefined;
      }
    };

    window.__anyuiApplyLang = applyDocLang;
    applyDocLang(readDocLang());

    if (!window.__anyuiLangBound) {
      window.__anyuiLangBound = true;
      document.addEventListener('astro:page-load', () => window.__anyuiApplyLang?.(readDocLang()));
      window.addEventListener('anyui:lang-change', (e) => window.__anyuiApplyLang?.(e.detail));
    }
  })();
</script>
