---
// Right-side table of contents with scrollspy. The menu itself is rendered with
// AnyUI's AListMenu so docs navigation has the same selected-state behavior as
// the left sidebars.
//
// Headings can be passed explicitly (from markdown getHeadings()); if omitted,
// the script scans the .prose article for h2/h3 elements and builds the TOC
// from the DOM (used by hand-written docs pages whose headings have no id).

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
}

import DocsToc from './vue/DocsToc.vue';

const { headings } = Astro.props;
const items = (headings || [])
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ depth: h.depth, slug: h.slug, text: h.text }));
---

<DocsToc client:load headings={items} auto={items.length === 0} />
