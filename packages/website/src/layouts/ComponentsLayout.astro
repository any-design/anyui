---
import BaseLayout from './BaseLayout.astro';
import { componentsByCategory } from '../data/components';
import ComponentsSidebar from '../components/vue/ComponentsSidebar.vue';
import LangToggle from '../components/vue/LangToggle.vue';

interface Props {
  title: string;
  active: string;
}

const { title, active } = Astro.props;
const groups = componentsByCategory();
---

<BaseLayout title={`${title} · AnyUI`} active="components">
  <div class="docs docs--components">
    <ComponentsSidebar client:load active={active} groups={groups} />

    <article class="prose">
      <div class="doc-toolbar">
        <slot name="toolbar" />
        <LangToggle client:load model-value="en" />
      </div>
      <slot />
    </article>
  </div>
</BaseLayout>