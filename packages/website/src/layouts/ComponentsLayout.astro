---
import BaseLayout from './BaseLayout.astro';
import { componentsByCategory, type CategoryMeta, type ComponentEntry } from '../data/components';
import ComponentsSidebar from '../components/vue/ComponentsSidebar.vue';
import LangToggle from '../components/vue/LangToggle.vue';
import type { BreadcrumbItem, SchemaType } from '../data/seo';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  active: string;
  schemaType?: SchemaType;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, description, canonicalPath, active, schemaType, breadcrumbs } = Astro.props;
const groups = componentsByCategory();

const mobileMenuGroups = [
  {
    label: '',
    items: [{ label: { en: 'Overview', zh: '概览' }, value: 'overview', href: '/components' }],
  },
  ...groups.map((g: { category: CategoryMeta; items: ComponentEntry[] }) => ({
    label: g.category.label,
    items: g.items.map((item) => ({ label: item.name, value: item.slug, href: `/components/${item.slug}` })),
  })),
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  active="components"
  schemaType={schemaType}
  breadcrumbs={breadcrumbs}
  mobileNavMenuGroups={mobileMenuGroups}
  mobileNavMenuActive={active}
  mobileNavMenuKind="components"
>
  <div class="docs docs--components">
    <ComponentsSidebar
      client:load
      transition:persist="components-sidebar"
      transition:persist-props
      active={active}
      groups={groups}
    />

    <article class="prose">
      <div class="doc-body">
        <slot />
      </div>
      <div class="doc-toolbar">
        <slot name="toolbar" />
        <LangToggle
          client:load
          transition:persist="components-lang-toggle"
          transition:persist-props
          model-value="en"
        />
      </div>
    </article>
  </div>
</BaseLayout>
