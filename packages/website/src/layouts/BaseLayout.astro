---
import { ClientRouter } from 'astro:transitions';
import BrandLogo from '../components/BrandLogo.astro';

import '../styles/site.scss';

interface Props {
  title?: string;
  description?: string;
  active?: string;
}

const {
  title = 'AnyUI — a cute multi-framework design system',
  description = 'AnyUI is a cute, fresh and modern design system and UI component library for Vue, React, and Svelte — with an optional liquid glass style.',
  active = '',
} = Astro.props;
---

<!doctype html>
<html lang="en" theme="light">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" /><link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
    <link rel="preconnect" to="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Load the code font as early as possible: preload the CSS so the fetch starts
      before render, then apply it. This avoids the code-block font swap (FOUC)
      that happens on every MPA navigation in the docs.
    -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap"
    />
    <script is:inline>
      // apply persisted theme before paint to avoid flashes.
      // Runs on first load (inline) AND after every client-side navigation
      // (astro:after-swap), so the theme attribute survives SPA routing.
      const applyTheme = () => {
        try {
          const prefs = JSON.parse(localStorage.getItem('anyui-site-prefs') || '{}');
          if (prefs.dark) document.documentElement.setAttribute('theme', 'dark');
          else document.documentElement.setAttribute('theme', 'light');
          if (prefs.glass) document.documentElement.setAttribute('data-anyui-style', 'glass');
          else document.documentElement.removeAttribute('data-anyui-style');
        } catch {}
      };
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
    <script is:inline>
      // Per-URL scroll restoration for SPA navigations.
      //
      // Astro's ClientRouter sets `history.scrollRestoration = "manual"` and only
      // restores scroll on back/forward (traverse) navigations via history.state.
      // A normal forward link navigation (e.g. clicking the Overview link in the
      // components sidebar after browsing a component detail page) is a "push",
      // so Astro always scrolls to the top — even when the destination was
      // visited before. That makes the /components Overview grid snap back to the
      // top every time you return to it via the sidebar, which feels broken.
      //
      // We keep a session-scoped map of URL → {x, y}, snapshot the scroll
      // position of the page we're leaving on astro:before-preparation, and
      // restore the saved position on astro:page-load for non-traverse
      // navigations. Traverse is left to Astro (it already restores from
      // history.state), and brand-new URLs have no saved entry so they still
      // scroll to the top as expected.
      (function () {
        if (window.__anyuiScrollRestoration) return;
        window.__anyuiScrollRestoration = true;
        const positions = new Map();
        const urlKey = (loc) => loc.pathname + loc.search + loc.hash;
        let pendingNavType = null;

        // Snapshot the outgoing page's scroll before we navigate away.
        // e.from / e.to are URL objects (pathname/search/hash/href).
        document.addEventListener('astro:before-preparation', (e) => {
          try {
            positions.set(urlKey(e.from), { x: window.scrollX, y: window.scrollY });
          } catch {}
          pendingNavType = e.navigationType;
        });

        // After the new page is in place, restore scroll if this was a forward
        // (push/replace) navigation to a URL we've visited before.
        document.addEventListener('astro:page-load', () => {
          const wasTraverse = pendingNavType === 'traverse';
          pendingNavType = null;
          if (wasTraverse) return; // Astro already restored from history.state
          const key = urlKey(window.location);
          const saved = positions.get(key);
          if (saved) {
            // Wait a frame so layout/images have settled before scrolling.
            requestAnimationFrame(() =>
              window.scrollTo({ left: saved.x, top: saved.y, behavior: 'instant' }),
            );
          }
        });
      })();
    </script>
    <!--
      Critical inline styles: set the background + base text color from the theme
      attribute BEFORE the main stylesheet loads, so MPA navigations don't flash a
      white background while the SCSS bundle parses. Mirrors the theme tokens.
    -->
    <style is:inline>
      html { background: #f8f8fa; color: #202426; }
      html[theme='dark'] { background: #1a1a1d; color: #ebeef1; }
      body { background: inherit; }
    </style>
  </head>
  <body>
    <div class="site-backdrop">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__brand" href="/" aria-label="AnyUI home">
          <BrandLogo />
        </a>
        <nav class="site-header__nav">
          <a href="/docs/getting-started" aria-current={active === 'docs' ? 'true' : undefined}
            >Docs</a
          >
          <a href="/components" aria-current={active === 'components' ? 'true' : undefined}>Components</a>
          <a href="https://anyui-testground.pwp.sh" target="_blank">Testground</a>
          <a href="https://github.com/any-design/anyui" target="_blank">GitHub</a>
        </nav>
        <div class="site-header__actions">
          <button class="site-toggle" id="toggle-dark" type="button">🌙 Dark</button>
          <button class="site-toggle" id="toggle-glass" type="button">🧊 Glass</button>
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>Made with 🧁 by <a href="https://github.com/any-design">Any Design</a></span>
        <a href="https://github.com/any-design/anyui">MIT Licensed</a>
      </div>
    </footer>

    <script>
      // Re-bind interactive UI on every page load (incl. client-side navigations
      // via <ClientRouter />). Listening to astro:page-load covers both the
      // initial load and every subsequent SPA navigation.
      const initPage = () => {
        const KEY = 'anyui-site-prefs';
        const read = () => {
          try {
            return JSON.parse(localStorage.getItem(KEY) || '{}');
          } catch {
            return {};
          }
        };
        const html = document.documentElement;
        const darkBtn = document.getElementById('toggle-dark');
        const glassBtn = document.getElementById('toggle-glass');

        if (darkBtn && glassBtn) {
          const sync = () => {
            darkBtn.dataset.on = String(html.getAttribute('theme') === 'dark');
            glassBtn.dataset.on = String(html.getAttribute('data-anyui-style') === 'glass');
          };
          darkBtn.addEventListener('click', () => {
            const dark = html.getAttribute('theme') !== 'dark';
            html.setAttribute('theme', dark ? 'dark' : 'light');
            localStorage.setItem(KEY, JSON.stringify({ ...read(), dark }));
            sync();
          });
          glassBtn.addEventListener('click', () => {
            const glass = html.getAttribute('data-anyui-style') !== 'glass';
            if (glass) {
              html.setAttribute('data-anyui-style', 'glass');
            } else {
              html.removeAttribute('data-anyui-style');
            }
            localStorage.setItem(KEY, JSON.stringify({ ...read(), glass }));
            sync();
          });
          sync();
        }

        // professional code blocks: language badge + copy button on every shiki block
        document.querySelectorAll('pre.astro-code').forEach((pre) => {
          // skip if already wrapped (e.g. persisted across a no-op swap)
          if (pre.parentElement && pre.parentElement.classList.contains('code-frame')) return;
          const frame = document.createElement('div');
          frame.className = 'code-frame';
          pre.parentNode.insertBefore(frame, pre);
          frame.appendChild(pre);
          const lang = pre.dataset.language;
          if (lang && lang !== 'plaintext') {
            const badge = document.createElement('span');
            badge.className = 'code-frame__lang';
            badge.textContent = lang;
            frame.appendChild(badge);
          }
          const copy = document.createElement('button');
          copy.className = 'code-frame__copy';
          copy.type = 'button';
          copy.textContent = 'Copy';
          copy.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(pre.innerText);
            } catch {
              const helper = document.createElement('textarea');
              helper.value = pre.innerText;
              document.body.appendChild(helper);
              helper.select();
              document.execCommand('copy');
              helper.remove();
            }
            copy.textContent = 'Copied!';
            setTimeout(() => (copy.textContent = 'Copy'), 1400);
          });
          frame.appendChild(copy);
        });
      };

      document.addEventListener('astro:page-load', initPage);
    </script>
  </body>
</html>
