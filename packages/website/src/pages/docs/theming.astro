---
import * as customizationDoc from '../../../../../docs/theme/customization.md';
import * as customizationZhDoc from '../../../../../docs/theme/customization.zh.md';

import LocalizedPage from '../../components/LocalizedPage.astro';
import { docSeo } from '../../data/seo';
import DocsLayout from '../../layouts/DocsLayout.astro';

const seo = docSeo('theming');
---

<DocsLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.path}
  active="theming"
  schemaType={seo.schemaType}
  breadcrumbs={seo.breadcrumbs}
  tocAuto
>
  <LocalizedPage>
    <Fragment slot="en">
      <customizationDoc.Content />
    </Fragment>
    <Fragment slot="zh">
      <customizationZhDoc.Content />
    </Fragment>
  </LocalizedPage>
</DocsLayout>
