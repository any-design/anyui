---
import * as iconsDoc from '../../../../../docs/theme/icons.md';
import * as iconsZhDoc from '../../../../../docs/theme/icons.zh.md';

import LocalizedPage from '../../components/LocalizedPage.astro';
import { docSeo } from '../../data/seo';
import DocsLayout from '../../layouts/DocsLayout.astro';

const seo = docSeo('icons');
---

<DocsLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.path}
  active="icons"
  schemaType={seo.schemaType}
  breadcrumbs={seo.breadcrumbs}
  tocAuto
>
  <LocalizedPage>
    <Fragment slot="en">
      <iconsDoc.Content />
    </Fragment>
    <Fragment slot="zh">
      <iconsZhDoc.Content />
    </Fragment>
  </LocalizedPage>
</DocsLayout>
