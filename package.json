{
  "name": "@any-design/anyui",
  "version": "0.4.0",
  "type": "module",
  "author": "any-design",
  "description": "A cute multi-framework UI component library",
  "files": [
    "dist",
    "styles",
    "README.md",
    "README-zh_CN.md",
    "LICENSE"
  ],
  "maintainers": [
    {
      "name": "backrunner",
      "url": "https://github.com/backrunner"
    }
  ],
  "keywords": [
    "vue",
    "react",
    "svelte",
    "ui",
    "library",
    "design-system",
    "cute"
  ],
  "homepage": "https://github.com/any-design/anyui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/any-design/anyui.git"
  },
  "packageManager": "pnpm@11.5.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "new": "node ./scripts/new.mjs",
    "start": "pnpm run dev:vue",
    "dev": "pnpm run dev:vue",
    "dev:vue": "pnpm --filter @any-design/anyui-vue dev",
    "clean": "rimraf dist styles packages/*/dist packages/vue/dist-testground",
    "generate": "node ./scripts/generate-framework-packages.mjs",
    "build": "pnpm run generate && turbo run build",
    "dist": "pnpm run clean && pnpm run build",
    "build:testground": "pnpm --filter @any-design/anyui-vue build:testground",
    "serve": "pnpm --filter @any-design/anyui-vue serve",
    "lint": "turbo run lint",
    "lint-fix": "turbo run lint-fix",
    "typecheck": "turbo run typecheck"
  },
  "main": "./dist/vue/anyui.mjs",
  "module": "./dist/vue/anyui.mjs",
  "types": "./dist/vue/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/anyui.mjs",
      "default": "./dist/vue/anyui.mjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/anyui.mjs",
      "default": "./dist/vue/anyui.mjs"
    },
    "./resolver": {
      "types": "./dist/vue/resolver.d.ts",
      "import": "./dist/vue/resolver.mjs",
      "require": "./dist/vue/resolver.cjs"
    },
    "./vue/resolver": {
      "types": "./dist/vue/resolver.d.ts",
      "import": "./dist/vue/resolver.mjs",
      "require": "./dist/vue/resolver.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "default": "./dist/react/index.mjs"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.mjs",
      "import": "./dist/svelte/index.mjs",
      "default": "./dist/svelte/index.mjs"
    },
    "./styles/*": "./styles/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "styles/**/*.css",
    "styles/**/*.scss",
    "**/*.svelte"
  ],
  "license": "MIT",
  "dependencies": {
    "async-validator": "^4.2.5",
    "color": "^5.0.3",
    "mitt": "^3.0.1"
  },
  "peerDependencies": {
    "@iconify/react": "^6.0.2",
    "@iconify/svelte": "^5.2.1",
    "@iconify/vue": "^5.0.1",
    "@popperjs/core": "^2.11.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "svelte": "^5.56.3",
    "vue": "^3.5.35"
  },
  "peerDependenciesMeta": {
    "@iconify/react": {
      "optional": true
    },
    "@iconify/svelte": {
      "optional": true
    },
    "@iconify/vue": {
      "optional": true
    },
    "@popperjs/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify/react": "^6.0.2",
    "@iconify/svelte": "^5.2.1",
    "@iconify/vue": "^5.0.1",
    "@popperjs/core": "^2.11.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/color": "^4.2.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "ejs": "^6.0.1",
    "fs-extra": "^11.3.5",
    "inquirer": "^14.0.2",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "sass": "^1.100.0",
    "svelte": "^5.56.3",
    "terser": "^5.48.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vite-plugin-gfont": "^0.2.0",
    "vue": "^3.5.35",
    "vue-tsc": "^3.3.4"
  }
}
